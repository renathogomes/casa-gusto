const msgLink=m=>`https://wa.me/${WHATSAPP}?text=${encodeURIComponent(m)}`;
function track(label){try{const s=JSON.parse(localStorage.getItem(KEY)||'{}');s[label]=(s[label]||0)+1;localStorage.setItem(KEY,JSON.stringify(s))}catch{}}
function openWA(message,label){track(label);window.open(msgLink(message),'_blank','noopener')}
document.querySelectorAll('[data-whatsapp]').forEach(el=>el.addEventListener('click',()=>openWA(el.dataset.message,el.dataset.whatsapp)));
document.querySelectorAll('.choices').forEach(group=>group.addEventListener('click',e=>{if(e.target.matches('.choice')){group.querySelectorAll('.choice').forEach(b=>b.classList.remove('active'));e.target.classList.add('active')}}));
const productData=JSON.parse(document.getElementById('productData').textContent);
const productCards=[...document.querySelectorAll('[data-product-card]')];
const searchInput=document.getElementById('productSearch');
const emptyProducts=document.getElementById('emptyProducts');
let activeFilter='Todos';
function applyProductFilters(){
  const term=(searchInput?.value||'').trim().toLowerCase();
  let visible=0;
  productCards.forEach(card=>{
    const matchFilter=activeFilter==='Todos'||card.dataset.category===activeFilter;
    const matchSearch=!term||card.dataset.title.includes(term);
    const show=matchFilter&&matchSearch;
    card.style.display=show?'':'none';
    if(show) visible++;
  });
  if(emptyProducts) emptyProducts.style.display=visible?'none':'block';
}
document.querySelectorAll('[data-filter]').forEach((btn,index)=>{
  if(index===0) btn.classList.add('active');
  btn.addEventListener('click',()=>{
    document.querySelectorAll('[data-filter]').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    activeFilter=btn.dataset.filter;
    applyProductFilters();
  });
});
searchInput?.addEventListener('input',applyProductFilters);
const modal=document.getElementById('productModal');
const modalCard=modal?.querySelector('.modal-card');
const modalClose=modal?.querySelector('.modal-close');
const modalImage=document.getElementById('modalImage');
const modalTag=document.getElementById('modalTag');
const modalCategory=document.getElementById('modalCategory');
const modalTitle=document.getElementById('modalTitle');
const modalDesc=document.getElementById('modalDesc');
const modalWeight=document.getElementById('modalWeight');
const modalPrice=document.getElementById('modalPrice');
const modalOptionsBlock=document.getElementById('modalOptionsBlock');
const modalOptions=document.getElementById('modalOptions');
const modalHighlights=document.getElementById('modalHighlights');
const modalPairings=document.getElementById('modalPairings');
const modalServing=document.getElementById('modalServing');
const modalRelated=document.getElementById('modalRelated');
const modalWhatsapp=document.getElementById('modalWhatsapp');
const modalShare=document.getElementById('modalShare');
let activeProduct=null;
function list(items){return (items||[]).map(item=>`<li>${item}</li>`).join('')}
function chips(items){return (items||[]).map(item=>`<span class="mini-chip">${item}</span>`).join('')}
function relatedCard(title){
  const related=productData.find(p=>p.title===title);
  if(!related) return '';
  const index=productData.indexOf(related);
  return `<button type="button" class="related-card" data-related-index="${index}"><img src="${related.image}" alt=""><span>${related.title}</span><strong>${related.price}</strong></button>`;
}
function productMessage(product){
  return `Olá! Gostaria de pedir: ${product.title} — ${product.weight} — ${product.price}.`;
}
function openProduct(index){
  const product=productData[index];
  if(!product) return;
  activeProduct=product;
  modalImage.src=product.image;
  modalImage.alt=product.title;
  modalTag.textContent=product.tag||product.brand||'';
  modalTag.style.display=product.tag||product.brand?'inline-flex':'none';
  modalCategory.textContent=product.category;
  modalTitle.textContent=product.title;
  modalDesc.textContent=product.detail||product.desc;
  modalWeight.textContent=product.weight;
  modalPrice.textContent=product.price;
  if(product.options?.length){
    modalOptionsBlock.style.display='block';
    modalOptions.innerHTML=product.options.map(option=>`<span class="option-pill">${option}</span>`).join('');
  }else{
    modalOptionsBlock.style.display='none';
    modalOptions.innerHTML='';
  }
  modalHighlights.innerHTML=list(product.highlights);
  modalPairings.innerHTML=chips(product.pairings);
  modalServing.innerHTML=list(product.serving);
  modalRelated.innerHTML=(product.suggestions||[]).map(relatedCard).join('');
  modal.classList.add('open');
  modal.setAttribute('aria-hidden','false');
  document.body.classList.add('modal-open');
  // Sempre abre os detalhes no início do conteúdo.
  // Antes, o foco no botão de WhatsApp fazia o modal rolar até o final.
  if(modalCard) modalCard.scrollTop = 0;
  requestAnimationFrame(() => {
    if(modalCard) modalCard.scrollTop = 0;
    modalClose?.focus({preventScroll:true});
  });
}
function closeProduct(){
  modal.classList.remove('open');
  modal.setAttribute('aria-hidden','true');
  document.body.classList.remove('modal-open');
}
productCards.forEach(card=>{
  card.addEventListener('click',e=>{if(e.target.closest('[data-modal-ignore]')) return; openProduct(Number(card.dataset.productIndex));});
  card.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' '){e.preventDefault();openProduct(Number(card.dataset.productIndex));}});
});
document.querySelectorAll('[data-close-modal]').forEach(el=>el.addEventListener('click',closeProduct));
modalRelated.addEventListener('click',e=>{const btn=e.target.closest('[data-related-index]');if(btn) openProduct(Number(btn.dataset.relatedIndex));});
modalWhatsapp.addEventListener('click',()=>{if(activeProduct) openWA(productMessage(activeProduct),`Produto modal: ${activeProduct.title}`)});
modalShare.addEventListener('click',async()=>{if(!activeProduct) return; const text=`${activeProduct.title} - ${activeProduct.desc}

Confira na Casa Gusto:`; if(navigator.share){try{return await navigator.share({title:`Casa Gusto | ${activeProduct.title}`,text,url:location.href})}catch{}} window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent(text+' '+location.href)}`,'_blank')});
document.addEventListener('keydown',e=>{if(e.key==='Escape') closeProduct();});
document.getElementById('kitForm').addEventListener('submit',e=>{e.preventDefault();const get=g=>document.querySelector(`[data-group="${g}"] .active`)?.textContent;if(!get('occasion')||!get('type')||!get('price')) return alert('Selecione as três opções para montar o kit.');openWA(`Olá, Casa Gusto! Gostaria de montar um kit.

Ocasião: ${get('occasion')}
Tipo: ${get('type')}
Valor desejado: ${get('price')}

Podem me enviar opções?`,'Monte seu Kit')});
document.querySelector('input[name="phone"]').addEventListener('input',e=>{let d=e.target.value.replace(/\D/g,'').slice(0,11);e.target.value=d.length<=2?`(${d}`:d.length<=6?`(${d.slice(0,2)}) ${d.slice(2)}`:d.length<=10?`(${d.slice(0,2)}) ${d.slice(2,6)}-${d.slice(6)}`:`(${d.slice(0,2)}) ${d.slice(2,7)}-${d.slice(7)}`});
document.getElementById('leadForm').addEventListener('submit',e=>{e.preventDefault();const f=new FormData(e.currentTarget), phone=String(f.get('phone')).replace(/\D/g,''); if(phone.length<10) return alert('Informe um WhatsApp válido.');openWA(`Olá, meu nome é ${f.get('name')}.

Meu WhatsApp: ${f.get('phone')}
Estou procurando: ${f.get('need')}
Observações: ${f.get('obs')||''}

Gostaria de mais informações.`,'Formulário Corporativo')});
document.querySelectorAll('[data-share]').forEach(el=>el.addEventListener('click',async()=>{const text=`${el.dataset.share} - ${el.dataset.desc}

Confira na Casa Gusto:`; if(navigator.share){try{return await navigator.share({title:`Casa Gusto | ${el.dataset.share}`,text,url:location.href})}catch{}} window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent(text+' '+location.href)}`,'_blank')}));
openStats.onclick=()=>{statsPanel.classList.toggle('open');let s={};try{s=JSON.parse(localStorage.getItem(KEY)||'{}')}catch{};statsContent.innerHTML=Object.keys(s).length?Object.entries(s).map(([k,v])=>`${k}: <strong>${v}</strong>`).join('<br>'):'Sem cliques registrados neste navegador.'};
clearStats.onclick=()=>{localStorage.removeItem(KEY);statsContent.textContent='Sem cliques registrados neste navegador.'};
</script>
</body></html>
