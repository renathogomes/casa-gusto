      <div class="actions">
        <button class="btn" data-whatsapp="Hero" data-message="Olá, vim pelo site da Casa Gusto e quero conhecer os produtos disponíveis.">☎ Pedir pelo WhatsApp</button>
        <a class="btn outline" href="#produtos">Ver produtos disponíveis ›</a>
