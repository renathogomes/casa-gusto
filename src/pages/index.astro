  </div>
</section>
<section id="produtos" class="section card">
  <div class="container">
    <div class="center"><h2>Produtos disponíveis</h2><p class="sub">Fotos reais dos produtos da Casa Gusto. Clique em qualquer item para ver descrição completa, harmonizações e sugestões para valorizar o pedido.</p></div>
    <div class="catalog-tools" aria-label="Filtros de produtos">
      <div class="filters">
        {categories.map(category => <button type="button" class="filter-chip" data-filter={category}>{category}</button>)}
      </div>
      <label class="search-box" aria-label="Buscar produto"><span>Buscar</span><input id="productSearch" type="search" placeholder="Ex: parmesão, doce, cachaça..." /></label>
    </div>
    <div class="grid products" id="productGrid">
      {products.map((product, index) => (
        <article class="product" data-product-card data-product-index={index} data-category={product.category} data-title={`${product.title} ${product.category} ${product.desc} ${product.detail} ${product.pairings?.join(' ')}`.toLowerCase()} tabindex="0" role="button" aria-label={`Ver detalhes de ${product.title}`}>
          <div class="pic">
            <img src={product.image} alt={product.title} loading="lazy" width="700" height="525" />
            {product.tag && <span class="tag">{product.tag}</span>}
            <button class="share" data-modal-ignore data-share={product.title} data-desc={product.desc} aria-label={`Compartilhar ${product.title}`}>↗</button>
          </div>
          <div class="product-body">
            <span class="category-label">{product.category}</span>
            <h3>{product.title}</h3>
            <p>{product.desc}</p>
            <div class="product-meta"><span>{product.weight}</span><strong>{product.price}</strong></div>
            <button class="btn outline detail-btn" type="button">Ver detalhes e sugestões</button>
          </div>
        </article>
      ))}
    </div>
    <p class="empty-message" id="emptyProducts">Nenhum produto encontrado com esse filtro.</p>
  </div>
</section>
<div class="product-modal" id="productModal" aria-hidden="true">
